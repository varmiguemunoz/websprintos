---
import Analytics     from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ViewTransitions } from 'astro:transitions';
import { SITE } from '@/data/seo';
import '@styles/global.css';

export interface Props {
  meta_title?:    string;
  title?:         string;
  description?:   string;
  image?:         string;
  noindex?:       boolean;
  keywords?:      string;
  schema?:        object | object[];
  /* Blog-post specific */
  type?:          'website' | 'article';
  pubDate?:       Date;
  updatedDate?:   Date;
  articleTags?:   string[];
  articleAuthor?: string;
}

const {
  title,
  meta_title,
  description  = SITE.description,
  image,
  noindex      = false,
  keywords     = SITE.keywords,
  schema,
  type         = 'website',
  pubDate,
  updatedDate,
  articleTags,
  articleAuthor = SITE.author.name,
} = Astro.props;

const pageTitle    = meta_title ?? title ?? SITE.title;
const canonicalURL = new URL(Astro.url.pathname, SITE.url).href;
const ogImage      = image ? (image.startsWith('http') ? image : `${SITE.url}${image}`) : SITE.ogImage;
const robotsContent = noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';

const schemas = schema
  ? Array.isArray(schema) ? schema : [schema]
  : [];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <!-- Charset always first -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={keywords} />
    <meta name="author"      content={SITE.author.name} />
    <meta name="robots"      content={robotsContent} />
    <meta name="theme-color" content="#0e0e10" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type"        content={type} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:image:alt"   content={`${SITE.name} — ${pageTitle}`} />
    <meta property="og:image:width" content="1731" />
    <meta property="og:image:height"content="909" />
    <meta property="og:site_name"   content={SITE.name} />
    <meta property="og:locale"      content={SITE.locale} />

    <!-- Article-specific Open Graph (blog posts) -->
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === 'article' && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {type === 'article' && articleTags?.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter / X Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content={SITE.twitterHandle} />
    <meta name="twitter:creator"     content={SITE.twitterHandle} />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />
    <meta name="twitter:image:alt"   content={`${SITE.name} — ${pageTitle}`} />

    <!-- Favicons — full set -->
    <link rel="icon"             type="image/x-icon"  href="/favicon.ico" />
    <link rel="icon"             type="image/png"      href="/favicon-16x16.png"  sizes="16x16" />
    <link rel="icon"             type="image/png"      href="/favicon-32x32.png"  sizes="32x32" />
    <link rel="icon"             type="image/png"      href="/favicons/favicon-192.png" sizes="192x192" />
    <link rel="icon"             type="image/png"      href="/favicons/favicon-256.png" sizes="256x256" />
    <link rel="apple-touch-icon"                       href="/apple-touch-icon.png" />
    <link rel="manifest"                               href="/site.webmanifest" />

    <!-- Resource hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://res.cloudinary.com" />

    <!-- Fonts — single load (no @import in CSS) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols — subset to only the icons we use -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=block"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    {schemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <slot name="head" />

    <ViewTransitions />
  </head>

  <body>
    <Analytics />
    <SpeedInsights />
    <slot />
  </body>
</html>
