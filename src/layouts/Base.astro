---
import Analytics    from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { ViewTransitions } from 'astro:transitions';
import '@styles/global.css';

export interface Props {
  meta_title?:  string;
  title?:       string;
  description?: string;
  image?:       string;
  noindex?:     boolean;
  keywords?:    string;
  schema?:      object | object[];
}

const {
  title,
  meta_title,
  description = 'The terminal-first project manager for developer teams.',
  noindex,
  keywords,
  schema,
} = Astro.props;

const pageTitle    = meta_title ?? title ?? 'SprintOS';
const canonicalURL = new URL(Astro.url.pathname, 'https://sprintos.dev').href;
const ogImage      = 'https://sprintos.dev/og.png';
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />

    <title>{pageTitle}</title>
    <meta name="title"       content={pageTitle} />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author"      content="varmiguemunoz" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={canonicalURL} />
    <link rel="shortcut icon" href="/favicon.ico" />

    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <meta name="theme-color" content="#0e0e10" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Inter:wght@300..700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
      rel="stylesheet"
    />

    {schema && (
      Array.isArray(schema)
        ? schema.map(s => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
        : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <slot name="head" />

    <ViewTransitions />
  </head>

  <body>
    <Analytics />
    <SpeedInsights />
    <slot />
  </body>
</html>
