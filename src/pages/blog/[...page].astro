---
export const prerender = true;

import { getCollection } from 'astro:content';
import Base              from '@/layouts/Base.astro';
import { Navbar }        from '@/components/organisms/Navbar';
import BlogGrid          from '@/components/organisms/BlogGrid.astro';
import SprintOSFooter    from '@/components/organisms/SprintOSFooter.astro';
import SectionLabel      from '@/components/atoms/SectionLabel.astro';
import { navigationItems, navCta, navPrimary } from '@/data/navigation';
import { footerLinks, footerMeta }             from '@/data/footer';
import { schemaBlogCollectionPage, schemaOrganization } from '@/data/seo';

export async function getStaticPaths({ paginate }: any) {
  const allPosts = await getCollection('blog');

  const sorted = allPosts
    .filter(p => p.data?.draft !== true)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(sorted, { pageSize: 7 });
}

const { page } = Astro.props as any;
const pageNum  = page?.currentPage ?? 1;

const posts = (page?.data ?? []).map((p: any) => ({
  slug:        p.slug,
  title:       p.data.title,
  description: p.data.description,
  pubDate:     new Date(p.data.pubDate),
  image:       p.data.image ?? '',
  category:    p.data.category ?? 'others',
  readtime:    p.data.readtime ?? '',
}));

const categories = [
  { id: 'all',             label: 'All Posts' },
  { id: 'dev-tips',        label: 'Dev Tips' },
  { id: 'automation',      label: 'Automation' },
  { id: 'ai-tools',        label: 'AI Tools' },
  { id: 'agency-workflow', label: 'Agency Workflow' },
  { id: 'tech-stack',      label: 'Tech Stack' },
];

const pageTitle = pageNum > 1
  ? `Blog — Page ${pageNum} — SprintOS`
  : 'Blog — SprintOS | Terminal Tooling, AI Agents & Developer Productivity';

const canonicalPath = pageNum > 1 ? `/blog/${pageNum}` : '/blog';
---

<Base
  meta_title={pageTitle}
  description="Technical deep-dives on terminal tooling, developer productivity, AI agents, MCP integrations, and production systems. No fluff — just what actually ships."
  keywords="developer blog, terminal tooling, CLI productivity, MCP agents, sprint planning, golang backend, AI automation, developer productivity tips"
  schema={[schemaBlogCollectionPage(pageNum), schemaOrganization()]}
>
  <Navbar
    client:load
    items={navigationItems}
    githubHref={navCta.href}
    ctaLabel={navPrimary.label}
    ctaHref={navPrimary.href}
  />

  <div class="pt-24 pb-6 bg-background relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 nebula-glow-top opacity-40"></div>
    <div class="site-container relative z-10">
      <SectionLabel label="Blog" accent="secondary" />
      <h1 class="font-display text-display-lg text-white mt-4 mb-4">
        Technical Depth, No Fluff.
      </h1>
      <p class="text-body-lg text-on-surface-variant max-w-xl">
        Architecture decisions, production patterns, and what actually ships in terminal-first developer tooling.
      </p>
    </div>
  </div>

  <div class="bg-background min-h-screen">
    <BlogGrid posts={posts} categories={categories} page={page} />
  </div>

  <SprintOSFooter groups={footerLinks} meta={footerMeta} />
</Base>
