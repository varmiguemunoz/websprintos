---
import { FaReact, FaWebflow, FaWordpress, FaShopify, FaNodeJs } from 'react-icons/fa6';
import { SiNextdotjs, SiTypescript, SiTailwindcss, SiPostgresql, SiOpenai, SiZapier, SiN8N } from 'react-icons/si';

interface Props {
  brands: {
    image: string;
    alt: string;
  }[];
}

const technologies = [
  { name: 'React', logo: FaReact },
  { name: 'Webflow', logo: FaWebflow },
  { name: 'Zapier', logo: SiZapier },
  { name: 'Wordpress', logo: FaWordpress },
  { name: 'Shopify', logo: FaShopify },
  { name: 'N8N', logo: SiN8N },
  { name: 'Next.js', logo: SiNextdotjs },
  { name: 'TypeScript', logo: SiTypescript },
  { name: 'TailwindCSS', logo: SiTailwindcss },
  { name: 'Node.js', logo: FaNodeJs },
  { name: 'PostgreSQL', logo: SiPostgresql },
  { name: 'OpenAI', logo: SiOpenai },
];
---

<section class="mx-auto w-full max-w-[1200px] border-b border-border/50 py-16">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mb-12 text-center">
      <p class="mb-6 text-sm font-medium text-muted-foreground">Trusted technologies and tools we work with</p>
    </div>

    <div class="grid grid-cols-3 items-center gap-8 md:grid-cols-6 lg:grid-cols-12">
      {
        technologies.map((tech) => {
          const Icon = tech.logo;

          return (
            <div class="group flex cursor-pointer flex-col items-center space-y-2">
              <div class="transform text-2xl opacity-50 transition-transform duration-300 group-hover:scale-110 group-hover:opacity-100 md:text-3xl">
                <Icon />
              </div>
              <span class="text-xs text-muted-foreground transition-colors group-hover:text-foreground">
                {tech.name}
              </span>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
