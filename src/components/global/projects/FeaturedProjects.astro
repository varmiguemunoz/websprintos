---
import projects from '@config/projects.json';
---

<section class="mx-auto max-w-screen-lg px-4 pb-12 sm:px-6 lg:px-8">
  <div class="mb-[30px]">
    <h3
      class="mb-1 mt-3 text-lg font-semibold leading-6 text-zinc-900 group-hover:text-zinc-600 dark:text-white md:text-xl"
    >
      Projects ⚡️
    </h3>
    <p class="text-md font-light opacity-70">Projects I have been involved in.</p>
  </div>

  <ul class="mx-auto grid grid-cols-1 gap-x-4 gap-y-4 text-white md:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
    {
      projects?.slice(0, 3).map((item) => (
        <li>
          <a href={item.url} target="_blank" class="relative top-0 block overflow-hidden">
            <div class="flex h-[180px] flex-col gap-4 rounded-xl border border-gray-300 bg-white px-4 py-4 hover:border-black dark:border-gray-800 dark:bg-zinc-900 dark:hover:border-gray-600">
              <div>
                <p class="h-8 text-lg font-bold text-black">{item.title}</p>
                <p class="text-md text-zinc-500">{item.description}</p>
              </div>

              <div class="flex items-center justify-start gap-[8px]">
                <div class="h-[10px] w-[10px] rounded-full bg-[#EBE934]" />
                <p class="text-[16px] font-normal capitalize">Javascript</p>
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</section>
