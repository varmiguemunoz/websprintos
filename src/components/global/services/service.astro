---
// Define the interface for the service data
interface ServiceData {
  generalTitle: string;
  generalDescription: string;
  services: {
    title: string;
    description: string;
    cta: string;
    ctaLink: string;
    features: string[];
    iconName: string;
  }[];
}

// Default data - can be overridden by props
const defaultData: ServiceData = {
  generalTitle: "Selected Work & Case Studies",
  generalDescription:
    "A curated selection of projects across e-commerce, SaaS, AI, and education technology. Each project reflects a focus on clean architecture, performance, and scalable digital experiences built for global audiences.",
  services: [
    {
      title: "DW Drums",
      description: "Global percussion e-commerce ecosystem",
      cta: "Visit project",
      ctaLink: "https://www.dwdrums.com/",
      features: [
        "Multi-brand e-commerce architecture for DW Drums, Pacific Drums, and LP Music",
        "Optimized for speed, SEO, and user experience across multiple domains",
        "Empowering musicians worldwide to explore, customize, and purchase percussion instruments online"
      ],
      iconName: "music"
    },
    {
      title: "Shipday",
      description: "AI-powered delivery & customer engagement platform",
      cta: "Explore platform",
      ctaLink: "https://www.shipday.com/",
      features: [
        "End-to-end delivery management with route optimization and real-time tracking",
        "AI system for automating communication and customer retention",
        "Improved operational efficiency and user satisfaction for logistics companies"
      ],
      iconName: "truck"
    },
    {
      title: "U-Corporative",
      description: "Corporate e-learning for Latin America",
      cta: "View platform",
      ctaLink: "https://laucorporativa.com/",
      features: [
        "Full-featured LMS for employee performance tracking and development",
        "Advanced analytics for organizational learning and HR evaluation",
        "Enabling businesses to manage talent growth and productivity effectively"
      ],
      iconName: "book-open"
    },
    {
      title: "Alpha Agent",
      description: "Lead generation Agency & conversion",
      cta: "Visit platform",
      ctaLink: "https://www.alphaagent.io/",
      features: [
        "Web platform for agents and brokers in the US to generate and convert qualified leads",
        "Integrated CRM, AI assistants, and automated dialers for sales automation",
        "Modern web experience highlighting brand authority and conversion-driven UX"
      ],
      iconName: "activity"
    }
  ]
};


// Accept props with default values
const { data = defaultData } = Astro.props;

// Icon mapping function
function getIcon(iconName: string): string {
  const icons: Record<string, string> = {
    'check-circle': `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    'zap': `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`,
    'users': `<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"></path></svg>`,
    'arrow-right': `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>`
  };
  return icons[iconName] || icons['check-circle'];
}
---

<section class="px-6 py-24 bg-gradient-background" id="services">
  <div class="mx-auto max-w-7xl">
    <!-- Header Section -->
    <div class="text-center mb-20">
      <h1 class="mb-8 text-4xl font-bold leading-tight text-foreground md:text-6xl lg:text-7xl">
        {data.generalTitle}
      </h1>
      
      <p class="mx-auto max-w-4xl text-xl leading-relaxed text-muted-foreground md:text-2xl">
        {data.generalDescription}
      </p>
    </div>

    <!-- Services Grid -->
    <div class="space-y-20 lg:space-y-32">
      {data.services.map((service: any, index: number) => (
        <div class={`grid gap-12 lg:gap-16 xl:gap-20 lg:grid-cols-2 items-center ${index % 2 === 0 ? '' : 'lg:grid-flow-col-dense'}`}>
          <!-- Content Column -->
          <div class={`space-y-8 ${index % 2 === 0 ? 'lg:order-1' : 'lg:order-2'}`}>
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div class="rounded-lg bg-accent/10 p-2 text-accent">
                  <Fragment set:html={getIcon(service.iconName)} />
                </div>
                <span class="text-sm font-medium text-accent uppercase tracking-wider">
                  {service.title}
                </span>
              </div>
              
              <h2 class="text-3xl font-bold leading-tight text-foreground md:text-4xl lg:text-5xl">
                {service.description}
              </h2>
            </div>

            <!-- Features List -->
            <div class="space-y-4">
              {service.features.map((feature: string) => (
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0 w-2 h-2 rounded-full bg-accent mt-3"></div>
                  <p class="text-lg text-muted-foreground leading-relaxed">
                    {feature}
                  </p>
                </div>
              ))}
            </div>

            <!-- CTA Button -->
            <div class="pt-4">
              <a 
                href={service.ctaLink} 
                class="group inline-flex items-center space-x-2 bg-gradient-primary hover:bg-gradient-primary/90 text-primary-foreground px-8 py-4 text-lg font-semibold rounded-lg transition-all duration-300 hover:shadow-glow"
              >
                <span>{service.cta}</span>
                <Fragment set:html={getIcon('arrow-right')} />
              </a>
            </div>
          </div>

          <!-- Visual Column -->
          <div class={`${index % 2 === 0 ? 'lg:order-2' : 'lg:order-1'}`}>
            <div class="relative">
              <!-- Placeholder for visual content - you can replace this with actual images or components -->
              <div class="aspect-[4/3] rounded-2xl bg-gradient-card border border-border/50 p-8 flex items-center justify-center">
                <div class="text-center space-y-4">
                  <div class="w-16 h-16 mx-auto rounded-full bg-accent/20 flex items-center justify-center text-accent">
                    <Fragment set:html={getIcon(service.iconName)} />
                  </div>
                  <h3 class="text-xl font-semibold text-foreground">{service.title}</h3>
                </div>
              </div>
              
              <!-- Decorative elements -->
              <div class="absolute -top-4 -right-4 w-24 h-24 rounded-full bg-gradient-accent opacity-20 blur-xl"></div>
              <div class="absolute -bottom-4 -left-4 w-32 h-32 rounded-full bg-gradient-primary opacity-10 blur-2xl"></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Custom styles for enhanced visual appeal */
  .bg-gradient-background {
    background: linear-gradient(180deg, hsl(var(--background)) 0%, hsl(222 84% 1.9%) 100%);
  }
  
  .group:hover svg {
    transform: translateX(0.25rem);
  }
</style>