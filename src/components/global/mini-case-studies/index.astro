---
// Props types
interface Stat {
  value: string;
  label: string;
}

interface CaseStudy {
  tag: string;
  title: string;
  description: string;
  stats: Stat[];
}

interface MiniCaseStudiesProps {
  heading?: string;
  descriptionDesktop?: string;
  descriptionMobile?: string;
  caseStudies?: CaseStudy[];
}

// Default props
const {
  heading = 'Case studies',
  descriptionDesktop = `With our Development Hour Packs, you get a reliable and flexible way to scale your tech capacity without the headaches of hiring full-time staff. Whether you need extra help for a specific project, ongoing support for multiple clients, or the ability to quickly scale your development power, our hour packs give your agency the freedom to grow with confidence.`,
  descriptionMobile = `With our Development Hour Packs, you get a reliable and flexible way to scale your tech capacity without the headaches of hiring full-time staff.`,
  caseStudies = [
    {
      tag: 'Automation',
      title: 'Automation that saved a marketing agency 60 hours per month.',
      description: 'We integrated ops tooling, pipelines, and alerts across their stack.',
      stats: [
        { value: '60+', label: 'hrs/month saved' },
        { value: '3', label: 'teams unblocked' },
      ],
    },
    {
      tag: 'Product',
      title: 'We launched an MVP in 8 days to validate an idea and secure investment.',
      description: 'Tight scope, robust architecture, and a demo-ready UI.',
      stats: [
        { value: '8', label: 'days to MVP' },
        { value: '🎯', label: 'investor-ready' },
      ],
    },
    {
      tag: 'Migration',
      title: 'We migrated a Shopify store with zero downtime and a 32% increase in conversion.',
      description: 'Seamless data transfer, performance tuning, and A/B driven UX changes.',
      stats: [
        { value: '0', label: 'downtime' },
        { value: '+32%', label: 'conversion' },
      ],
    },
  ],
} = Astro.props as MiniCaseStudiesProps;
---

<section id="mini-case-studies" class="px-4 py-16 sm:py-20">
  <div class="mx-auto w-full max-w-7xl">
    <div class="mb-10 flex items-end justify-between gap-6">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{heading}</h2>
        <p class="mt-2 hidden text-justify text-muted-foreground md:block">{descriptionDesktop}</p>
        <p class="mt-2 block text-muted-foreground md:hidden">{descriptionMobile}</p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        caseStudies.map((study) => (
          <article class="group relative overflow-hidden rounded-2xl border border-border bg-gradient-card p-6 transition-all duration-300 hover:border-primary/20 hover:shadow-glow">
            <div class="mb-6 flex items-center justify-between">
              <div class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">{study.tag}</div>
            </div>
            <h3 class="mb-3 text-xl font-semibold text-foreground">{study.title}</h3>
            <p class="mb-5 text-sm text-muted-foreground">{study.description}</p>
            <div class="flex items-center gap-3">
              {study.stats.map((stat) => (
                <div class="rounded-md border border-border/60 bg-secondary/30 px-3 py-2 text-sm text-foreground">
                  <span class="font-semibold text-accent">{stat.value}</span> {stat.label}
                </div>
              ))}
            </div>
            <div class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-gradient-to-br from-primary/20 to-accent/20 blur-2xl transition-all duration-300 group-hover:scale-110" />
          </article>
        ))
      }
    </div>
  </div>
</section>
