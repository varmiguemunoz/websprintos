---
import { Button } from '@/components/ui/button';
import { ArrowRight, ArrowDown } from 'lucide-react';
---

<section class="relative flex min-h-[90vh] items-center overflow-hidden px-6 py-24 lg:py-32">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-accent/10"></div>
  <div
    class="from-primary/15 absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] via-transparent to-transparent"
  >
  </div>

  <!-- Decorative Orbs -->
  <div class="absolute -left-32 top-1/4 h-64 w-64 rounded-full bg-primary/10 blur-[100px]"></div>
  <div class="absolute -right-32 bottom-1/4 h-64 w-64 rounded-full bg-accent/10 blur-[100px]"></div>

  <div class="relative z-10 mx-auto max-w-6xl">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Eyebrow -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/10 px-4 py-2">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
        </span>
        <span class="text-sm font-medium text-accent">Available for freelance projects</span>
      </div>

      <!-- Headline -->
      <h1
        class="mb-6 text-4xl font-bold leading-tight tracking-tight text-foreground md:text-5xl lg:text-6xl xl:text-7xl"
      >
        I Build the Systems Your Business
        <span class="bg-gradient-to-r from-foreground via-primary to-accent bg-clip-text text-transparent">
          Actually Needs
        </span>
         to Scale
      </h1>

      <!-- Subheadline -->
      <p class="mx-auto mb-10 max-w-3xl text-lg leading-relaxed text-muted-foreground md:text-xl">
        Senior Full-Stack Engineer specialized in AI systems, scalable backends, and business automation. 5+ years
        shipping production infrastructure for startups, agencies, and business owners.
      </p>

      <!-- Stats Bar -->
      <div
        class="mx-auto mb-10 flex max-w-2xl flex-wrap items-center justify-center gap-8 rounded-2xl border border-border/30 bg-card/30 px-8 py-6 backdrop-blur-sm md:gap-12"
      >
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground md:text-4xl">15+</div>
          <div class="mt-1 text-xs uppercase tracking-widest text-muted-foreground">AI Systems Shipped</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground md:text-4xl">10,000+</div>
          <div class="mt-1 text-xs uppercase tracking-widest text-muted-foreground">Operations/Day</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-bold text-foreground md:text-4xl">7,000+</div>
          <div class="mt-1 text-xs uppercase tracking-widest text-muted-foreground">Active Users</div>
        </div>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs"
        >
          <Button variant="hero" size="xl" className="group">
            Book a Discovery Call
            <ArrowRight className="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" />
          </Button>
        </a>
        <a href="#work">
          <Button variant="outline" size="xl" className="hover:bg-white hover:text-black">
            View My Work
            <ArrowDown className="ml-2 h-5 w-5" />
          </Button>
        </a>
      </div>

      <!-- Microcopy -->
      <p class="mt-6 text-sm text-muted-foreground/60">
        No commitment. 30-minute call. I'll tell you exactly how I'd approach your project.
      </p>
    </div>
  </div>
</section>
