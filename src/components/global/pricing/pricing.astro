---
import { Badge } from '@/components/ui/badge';
import { Check } from 'lucide-react';
import GetStartedButton from './get-started-button';

type Plan = {
  name: string;
  description: string;
  price: number;
  stripePriceId: string;
  redirectUrl?: string;
  hours: string;
  popular: boolean;
  number_plans?: number;
  features: string[];
};

const FEATURES_PLANS: Plan[] = [
  {
    name: 'Launch',
    description: 'Perfect for small agencies getting started',
    price: 2500,
    stripePriceId: 'price_1RoIIJDOnhjqrRNXiH0M9l3S',
    hours: '40',
    popular: false,
    features: [
      '40 hours flexible hours development (web, mobile, scripting, infrastructure, automations)',
      'Slack communication channel',
      'Weekly progress updates',
      'Emergency support (4hr response)',
      'Code reviews & architecture guidance',
    ],
  },
  {
    name: 'Scale',
    description: 'For growing agencies with consistent dev needs',
    price: 4000,
    stripePriceId: 'price_1RoIJDDOnhjqrRNXSygb3J7T',
    hours: '80',
    popular: true,
    features: [
      '80 hours of flexible development (web, mobile, scripting, infrastructure, automations)',
      'Slack communication channel',
      'Weekly progress updates',
      'Emergency support (2hr response)',
      'Code reviews & architecture guidance',
      'Monthly strategy & planning call',
      'Discount on extra hours',
    ],
  },
  {
    name: 'Partner+',
    description: 'Full technical partnership for agencies',
    price: 5500,
    stripePriceId: 'price_1RoIK3DOnhjqrRNXstinWLdK',
    hours: '120',
    popular: false,
    features: [
      '120 hours flexible development (web, mobile, scripting, infrastructure, automations)',
      'Slack communication channel',
      'Weekly progress updates',
      'Emergency support (1hr response)',
      'Code reviews & architecture guidance',
      'Weekly strategy & planning calls',
      'Dedicated Project Manager',
      'Custom integrations & tooling',
      'Discount on extra hours ($20/h)',
    ],
  },
];

type Props = {
  title?: string;
  description?: string;
  plan?: Plan[];
};

const {
  title = 'Predictable Dev Power for Digital Agencies',
  description = 'Choose your plan based on development hours needed. Scale up or down as your agency grows.',
  plan = FEATURES_PLANS,
} = Astro.props;
---

<section class="px-4 py-24" id="pricing">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <Badge variant="outline" className="mb-4 border-primary text-primary">Pricing & Plans</Badge>
      <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">{title}</h2>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        {description}
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-border">
            <th class="px-4 py-6 text-left font-medium text-muted-foreground">Plan Features</th>
            {
              plan.map((plan) => (
                <th class="min-w-[280px] px-4 py-6 text-center">
                  <div class="relative">
                    {plan.popular && (
                      <Badge className="bg-primary absolute -top-2 left-1/2 -translate-x-1/2 transform text-white">
                        Most Popular
                      </Badge>
                    )}
                    <div class="rounded-lg border border-border bg-gradient-card p-6 transition-all duration-300 hover:border-primary/20 hover:shadow-glow">
                      <h3 class="mb-2 text-2xl font-bold text-foreground">{plan.name}</h3>
                      <p class="mb-4 text-sm text-muted-foreground">{plan.description}</p>
                      <div class="mb-6">
                        <span class="text-4xl font-bold text-primary">${plan.price.toLocaleString()}</span>
                        <span class="text-muted-foreground">/month</span>
                      </div>
                      <GetStartedButton plan={plan} client:load />
                    </div>
                  </div>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {/* Get max features length for consistent rows */}
          {
            Array.from({ length: Math.max(...plan.map((p) => p.features.length)) }, (_, i) => (
              <tr class="border-b border-border/50">
                <td class="px-4 py-4 text-muted-foreground">
                  {plan[plan.length - 1].features[i] && (
                    <div class="flex items-center space-x-2">
                      <span>
                        {plan[plan.length - 1].features[i]
                          ?.replace(/^\d+\s+hours?\s+/, '')
                          .replace(/^[A-Z]/, (c) => c.toLowerCase())}
                      </span>
                    </div>
                  )}
                </td>
                {plan.map((plan) => (
                  <td class="px-4 py-4 text-center">
                    {plan.features[i] ? (
                      <div class="flex items-center justify-center space-x-2">
                        <Check className="text-accent h-5 w-5" />
                        <span class="text-sm text-foreground">
                          {plan.features[i].match(/^\d+\s+hours?/) ? plan.features[i].match(/^\d+\s+hours?/)?.[0] : '✓'}
                        </span>
                      </div>
                    ) : (
                      <span class="text-muted-foreground">—</span>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="mt-12 text-center">
      <a href="/predictable-dev-power-for-digital-agencies.pdf">
        <p class="text-muted-foreground">
          Looking for a tailored solution or want to explore our full range of services?
          <span class="ml-1 cursor-pointer text-primary hover:underline">View full service catalog →</span>
        </p>
      </a>
    </div>
  </div>
</section>
