        <BookCallButton label="Book your free discovery call 🚀" link="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs" />
      </div>

<div class="mb-16 text-center hidden md:block">
  <Badge variant="outline" className="mb-4 border-primary text-primary">
    Proven Revenue Systems
  </Badge>

  <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">
    See the Two Systems Businesses Use to Close More Deals
  </h2>

  <p class="mx-auto max-w-3xl text-xl text-muted-foreground mb-10">
    Book a free demo call to see how these systems generate qualified leads, automate follow-ups, and turn conversations into booked meetings and revenue for service businesses.
  </p>

  <BookCallButton label="Book your free discovery call 🚀" link="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs" />
</div>

    </div>
  </div>
</section>

<script>
const handleClick = async (priceId: string, planName: string) => {
    try {

      const res = await fetch('/api/create-checkout-projects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          priceId: priceId,
          planName: planName
        }),
      });

      if (!res.ok) throw new Error('Failed to create Stripe Checkout Session.');

      const { url } = await res.json();
      if (!url) throw new Error('Missing Checkout URL from server.');

      window.location.href = url;
    } catch (_er) {
      alert('The payment process could not be initiated. Please try again');
    }
  };

  // Add click event listeners to all service rows
  document.addEventListener('DOMContentLoaded', () => {
    const serviceRows = document.querySelectorAll('tr[data-price-id]');

    serviceRows.forEach((row) => {
      const priceId = row.getAttribute('data-price-id');
      const book = row.getAttribute('data-book') === 'true';
      const planName = row.getAttribute('data-plan-name');

      if (book) {
        row.addEventListener('click', async() => {
          window.location.href = 'https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs';
        });
      }

      // Only add click listener if all required data is present
      if (priceId && planName) {
        row.addEventListener('click', async() => {
         await handleClick(priceId, planName);
        });
      }
    });
  });
</script>
