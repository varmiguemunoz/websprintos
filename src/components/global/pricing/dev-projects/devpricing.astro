---

<section class="px-4 py-24" id="services">
  <div class="mx-auto max-w-7xl">
    <div class="mb-16 text-center">
      <Badge variant="outline" className="mb-4 border-primary text-primary">Service Catalog 2025</Badge>
      <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">Complete Solutions for Agencies</h2>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        From conversion-focused landing pages to revenue-driven e-commerce and business-ready infrastructure. Get one-time projects with transparent pricing and fast delivery. Grow your brand and sales without hidden costs or long processes
      </p>
    </div>

    <p class="text-muted-foreground text-sm text-center w-full mb-3">Click any service in the table to purchase instantly. 👇🏻</p>
    <div class="overflow-x-auto rounded-lg border border-primary/20 shadow-lg">
      <table class="w-full border-collapse min-w-[800px]">
        <thead class="">
          <div class="w-[80rem]">
            <tr class="bg-black w-full from-primary to-accent">
            <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider sm:px-6 sm:py-4 sm:text-sm">
              Services
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider sm:px-6 sm:py-4 sm:text-sm">
              Service Consideration
            </th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-white uppercase tracking-wider sm:px-6 sm:py-4 sm:text-sm">
              Cost
            </th>
          </tr>
          </div>

        </thead>
        <tbody>
          {
            services.map((service) => (
              <>
                <!-- Category Header Row -->
                <tr class="bg-gradient-to-r from-black to-gray-800">
                  <td colspan="3" class="border border-primary/20 px-4 py-3 text-center text-base font-bold text-white sm:px-6 sm:py-4 sm:text-lg">
                    {service.category}
                  </td>
                </tr>

                {service.items.map((item, index) => (
                  <tr id={`service-${item.name.replace(/\s+/g, '-').toLowerCase()}`}
                    data-price-id={item.priceId || ''}
                    data-plan-name={item.name || ''}
                    data-price={item.price?.replace('$', '') || ''}
                    data-book={item.book || false}
                    class={`transition-all duration-300 hover:bg-gradient-to-r hover:from-primary/5 hover:to-accent/5 ${index % 2 === 0 ? 'bg-gradient-to-r from-accent/10 to-primary/5' : 'bg-gradient-to-r from-primary/5 to-accent/10'}`}>
                    <td class="border border-primary/20 px-4 py-3 text-xs font-medium text-foreground sm:px-6 sm:py-4 sm:text-sm">
                      <div>
                        <div class="font-semibold">{item.name}</div>
                        {item.note && <div class="text-xs text-accent mt-1">{item.note}</div>}
                      </div>
                    </td>
                    <td class="border border-primary/20 px-4 py-3 text-xs text-muted-foreground sm:px-6 sm:py-4 sm:text-sm">
                      {item.description || '-'}
                    </td>
                    <td class="border border-primary/20 px-4 py-3 text-xs font-bold text-primary sm:px-6 sm:py-4 sm:text-sm">
                      {item.price || 'Get a quote'}
                    </td>
                  </tr>
                ))}
              </>
            ))
