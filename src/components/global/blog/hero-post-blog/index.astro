---
import { Tag, Calendar, Clock } from 'lucide-react';
import { Badge } from '@/components/ui/badge';

type Props = {
  blogPost: {
    slug: string;
    data: {
      id: string;
      category: string;
      featured: string;
      title: string;
      subtitle: string;
      publishDate: string;
      readTime: string;
    };
  };
  formatDate: (arg: any) => void;
};

const { blogPost, formatDate } = Astro.props;
---

<section class="w-full overflow-x-hidden px-4 pb-12 pt-24">
  <div class="mx-auto w-full max-w-4xl">
    <div class="relative w-full">
      {/* Background glow effect */}
      <div class="absolute inset-0 w-full rounded-full bg-gradient-primary opacity-5 blur-3xl md:scale-150"></div>

      <div class="relative w-full text-center">
        {/* Category and Featured Badge */}
        <div class="mb-6 flex items-center justify-center gap-3">
          <Badge variant="outline" className="border-primary/30 text-primary-glow">
            <Tag className="mr-1 h-3 w-3" />
            {blogPost.data.category}
          </Badge>
          {
            blogPost.data.featured && (
              <Badge className="border-primary/30 bg-gradient-primary text-primary-foreground">Featured</Badge>
            )
          }
        </div>

        {/* Title */}
        <h1 class="mb-6 text-4xl font-bold leading-tight text-foreground md:text-5xl lg:text-6xl">
          {blogPost.data.title}
        </h1>

        {/* Subtitle */}
        <p class="mx-auto mb-8 max-w-3xl text-xl leading-relaxed text-muted-foreground md:text-2xl">
          {blogPost.data.subtitle}
        </p>

        {/* Meta Information */}
        <div class="flex flex-wrap items-center justify-center gap-6 text-sm text-muted-foreground">
          <div class="flex items-center">
            <Calendar className="mr-2 h-4 w-4" />
            {formatDate(blogPost.data.publishDate)}
          </div>
          <div class="flex items-center">
            <Clock className="mr-2 h-4 w-4" />
            {blogPost.data.readTime}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
