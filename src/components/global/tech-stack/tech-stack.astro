---
import { Badge } from '@/components/ui/badge';

const categories = [
  {
    label: 'Backend',
    techs: ['Go (Golang)', 'Node.js', 'NestJS', 'Express'],
  },
  {
    label: 'Frontend',
    techs: ['Next.js 15', 'React', 'TypeScript', 'Tailwind CSS'],
  },
  {
    label: 'AI',
    techs: ['OpenAI API', 'Anthropic Claude', 'RAG', 'Multi-agent systems'],
  },
  {
    label: 'Mobile',
    techs: ['React Native'],
  },
  {
    label: 'Infrastructure',
    techs: ['AWS', 'GCP', 'Docker', 'Kubernetes', 'Vercel', 'Render'],
  },
  {
    label: 'Databases',
    techs: ['PostgreSQL', 'MongoDB', 'Redis'],
  },
  {
    label: 'Integrations',
    techs: ['WhatsApp Business API', 'GHL', 'Supabase', 'Airtable', 'CRMs'],
  },
];
---

<section class="px-6 py-24" id="stack">
  <div class="mx-auto max-w-6xl">
    <!-- Header -->
    <div class="mb-16 text-center">
      <Badge variant="outline" className="mb-6 border-primary text-primary">Stack</Badge>
      <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">Tech Stack</h2>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        The tools I use in production. No certifications — battle-tested systems.
      </p>
    </div>

    <!-- Stack Grid -->
    <div class="mx-auto max-w-4xl space-y-6">
      {categories.map((category) => (
        <div class="flex flex-col items-start gap-4 rounded-xl border border-border/20 bg-card/20 p-5 transition-all duration-300 hover:border-primary/10 hover:bg-card/40 sm:flex-row sm:items-center">
          <span class="min-w-[120px] text-sm font-semibold uppercase tracking-wider text-primary">
            {category.label}
          </span>
          <div class="flex flex-wrap gap-2">
            {category.techs.map((tech) => (
              <span class="rounded-full bg-primary/10 px-3 py-1 text-sm text-primary">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
