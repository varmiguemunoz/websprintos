---

---

<section class="w-full bg-white py-5 md:py-20">
  <div class="mx-auto grid w-full items-center gap-10 md:grid-cols-2">
    <!-- Texto -->
    <div>
      <h1 class="mb-6 text-4xl font-bold leading-tight md:text-5xl">
        Boost sales and <br />
         customer loyalty with<br />
        <span class="text-blue-600"> AI-powered agents</span>
      </h1>
      <p class="mb-4 text-lg text-gray-600">
        Streamline your order management, engage more customers, and grow your revenue with 24/7 smart AI agents on all
        your platforms.
      </p>
      <div class="mb-6 flex items-center space-x-2 text-sm text-gray-700">
        <span>⭐ 4.7</span>
        <span>•</span>
        <span>4,000+ clients</span>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href="/sales#form"
          class="rounded-xl bg-blue-600 px-6 py-3 font-medium text-white transition hover:bg-blue-700"
        >
          Get started
        </a>
        <a
          href="/sales#form"
          class="rounded-xl border border-blue-600 px-6 py-3 font-medium text-blue-600 transition hover:bg-blue-50"
        >
          Request a demo
        </a>
      </div>
    </div>

    <!-- Imagen -->
    <div class="relative">
      <img
        src="/sapify.png"
        alt="Agente IA trabajando"
        class="w-full"
        width="500"
        height="500"
        loading="lazy"
        referrerpolicy="no-referrer"
      />

      <!-- Ficha de usuario -->
      <div class="absolute right-4 top-4 hidden w-56 rounded-xl border bg-white px-4 py-2 text-sm shadow-md md:block">
        <div class="mb-1 font-semibold text-gray-800">✨ AI Responded</div>
        <p class="text-gray-600">
          Automate your sales process and let AI handle first contact, follow-ups, and even lead qualification.
        </p>
      </div>

      <!-- Insights -->
      <div class="absolute bottom-4 right-4 w-56 rounded-xl border bg-white px-4 py-2 text-sm shadow-md">
        <div class="font-semibold text-gray-800">📊 AI chat</div>
        <p class="text-gray-600">
          Respond to questions, complaints, or requests with intelligent agents available 24/7 on all your channels.
        </p>
      </div>

      <!-- Asignación -->
      <div class="absolute bottom-4 left-4 hidden w-56 rounded-xl border bg-white px-4 py-2 text-sm shadow-md md:block">
        <div class="font-semibold text-gray-800">🧠 AI Business</div>
        <ul class="mt-1 text-gray-600">
          <li>We build AI agents tailored to your business rules, tone, and workflows.</li>
        </ul>
      </div>
    </div>
  </div>
</section>
