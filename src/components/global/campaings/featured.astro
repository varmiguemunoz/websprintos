---

---

<section class="bg-white py-5 md:py-24 px-4 md:px-12">
  <div class="max-w-7xl mx-auto">
    {/* Título principal */}
    <div class="md:flex md:justify-between md:items-start mb-16">
      <div class="max-w-2xl">
        <h2 class="text-4xl font-bold text-black leading-tight">
          <span class="text-blue-600">Instant responses.</span><br />
          No commissions.<br />
          More sales, less work.
        </h2>
      </div>
      <div
        class="mt-6 md:mt-0 md:max-w-xl text-gray-600 text-lg leading-relaxed"
      >
        <p>
          Our AI agents work for you 24 hours a day, 7 days a week, across all
          your channels, managing orders, answering frequently asked questions,
          automating the sales process, qualifying leads, and automatically
          assigning deliveries. Forget about hiring more staff: with our AI
          agent services, you'll sell more, provide faster service, and grow
          with ease.
        </p>
      </div>
    </div>

    {/* Tarjetas */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {/* Tarjeta 1 */}
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
        <div class="mb-4">
          <span class="inline-block bg-blue-100 p-2 rounded-full">
            {/* Icono personalizado aquí, por ahora placeholder */}
            <svg
              class="w-6 h-6 text-blue-600"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9 12l-2-2-1 1 3 3 6-6-1-1-5 5z"></path>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold text-black mb-2">
          Sell More, Automatically
        </h3>
        <p class="text-gray-600 mb-4">
          Our AI agents handle orders, answer FAQs, automate sales, qualify
          leads, and assign deliveries, across all your channels, saving your
          time and effort.
        </p>
        <a href="/sales#form" class="text-blue-600 font-medium hover:underline"
          >Contact sales</a
        >
      </div>

      {/* Tarjeta 2 */}
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
        <div class="mb-4">
          <span class="inline-block bg-blue-100 p-2 rounded-full">
            {/* Icono */}
            <svg
              class="w-6 h-6 text-blue-600"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M4 4h16v2H4V4zm0 4h16v2H4V8zm0 4h10v2H4v-2zm0 4h8v2H4v-2z"
              ></path>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold text-black mb-2">
          Automate Repetitive Work
        </h3>
        <p class="text-gray-600 mb-4">
          Free your team from manual tasks. Our AI Agents handle scheduling,
          data entry, and internal processes — all tailored to your business.
        </p>
        <a href="/sales#form" class="text-blue-600 font-medium hover:underline"
          >Contact sales</a
        >
      </div>

      {/* Tarjeta 3 */}
      <div class="bg-gray-50 p-6 rounded-xl shadow-sm">
        <div class="mb-4">
          <span class="inline-block bg-blue-100 p-2 rounded-full">
            {/* Icono */}
            <svg
              class="w-6 h-6 text-blue-600"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M20 8h-3.17l-1.84-2.47A1 1 0 0014.34 5H5a1 1 0 000 2h8.34l1.84 2.47a1 1 0 00.82.41H20a1 1 0 000-2zm-3 4a1 1 0 100 2h2a1 1 0 100-2h-2zm-2 4a1 1 0 100 2h4a1 1 0 100-2h-4z"
              ></path>
            </svg>
          </span>
        </div>
        <h3 class="text-lg font-semibold text-black mb-2">
          Custom AI for Your Workflow
        </h3>
        <p class="text-gray-600 mb-4">
          Whether it's sales, HR, logistics or customer service — we build AI
          solutions tailored to your exact processes and KPIs.
        </p>
        <a href="/sales#form" class="text-blue-600 font-medium hover:underline"
          >Contact sales</a
        >
      </div>
    </div>
  </div>
</section>
