---
type Props = {
  url?: string;
};

const { url = '#form' } = Astro.props;
---

<div
  class="mx-auto mb-10 flex w-full max-w-[1240px] flex-col justify-evenly gap-7 rounded-xl border border-gray-300 px-4 py-16 sm:px-8 lg:flex-row lg:px-12"
>
  <div class="flex flex-col justify-center gap-2 text-center md:text-left">
    <h1 class="text-3xl font-bold leading-tight sm:text-3xl">Only 5 free implementations this month</h1>

    <p class="font-normal text-gray-500">Don't miss this opportunity to get your AI Agent for free</p>
  </div>

  <div class="flex justify-center">
    <a href={url}>
      <span>Get in touch</span>
    </a>
  </div>
</div>
