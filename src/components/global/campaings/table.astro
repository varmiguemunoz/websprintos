<section class="bg-white md:py-20 py-10 px-6">
  <div class="max-w-7xl mx-auto text-center">
    <p class="text-blue-600 font-semibold text-sm mb-2">Pricing and planes</p>
    <h2 class="text-3xl md:text-4xl font-bold mb-12">
      Start free, choose a plan later.
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-3 text-left w-full border max-w-[1100px] mx-auto"
    >
      <!-- Plan 1 -->
      <div
        class="border-blue-500 rounded-xl py-12 px-6 flex flex-col justify-start"
      >
        <div>
          <h3 class="font-semibold text-lg mb-2">AI Started</h3>
          <p class="text-sm text-gray-600 mb-4">
            Entrepreneurs or small businesses that want to start automating
