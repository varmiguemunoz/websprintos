---
import { Button } from '@/components/ui/button';
import { ArrowRight } from 'lucide-react';
---

<section class="relative overflow-hidden px-6 py-24 lg:py-32">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-accent/5 to-primary/10"></div>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--tw-gradient-stops))] from-accent/10 via-transparent to-transparent"
  >
  </div>

  <!-- Decorative Orbs -->
  <div class="absolute -left-20 bottom-0 h-48 w-48 rounded-full bg-primary/10 blur-[80px]"></div>
  <div class="absolute -right-20 top-0 h-48 w-48 rounded-full bg-accent/10 blur-[80px]"></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl lg:text-6xl">
      Ready to Build Something That
      <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent"> Actually Works?</span>
    </h2>

    <p class="mx-auto mb-10 max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl">
      Whether you need to automate your entire operation, scale your agency's delivery, or build your startup's core
      product — let's spend 30 minutes figuring out exactly how.
    </p>

    <a
      href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs"
    >
      <Button variant="hero" size="xl" className="group">
        Book a Discovery Call
        <ArrowRight className="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" />
      </Button>
    </a>

    <p class="mt-6 text-sm text-muted-foreground/60">No commitment required · I'll respond within 24 hours</p>
  </div>
</section>
