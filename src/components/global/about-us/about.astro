---
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { ExternalLink, Linkedin } from 'lucide-react';
import OptimizedVideo from '../optimized-video/OptimizedVideo';
import Avatar from '@/components/global/avatar/Avatar.astro';
import LinkedAccounts from './linked-accounts/LinkedAccounts.astro';
import { FaCircleCheck } from 'react-icons/fa6';

const stats = [
  {
    title: 'WhatsApp Conversations Automated',
    value: '1,000+',
  },
  {
    title: 'Production AI Systems Shipped',
    value: '25+',
  },
  {
    title: 'Daily Operations Automated',
    value: '10,000+',
  },
];

const myAccounts = [
  {
    platform: 'GitHub',
    username: 'Miguel Angel Muñoz',
    since: '2021',
    profileUrl: 'https://github.com/varmiguemunoz',
    avatarUrl: '/headshot.png',
    followers: '7 followers',
  },
  {
    platform: 'LinkedIn',
    username: 'Miguel Angel Muñoz',
    since: '2020',
    profileUrl: 'https://www.linkedin.com/in/varmiguemunoz/',
    avatarUrl: '/headshot.png',
    followers: '500+ connections',
  },
  {
    platform: 'Upwork',
    username: 'Miguel Angel M.',
    since: '2022',
    profileUrl: 'https://www.upwork.com/freelancers/~01c50c885bdb2a6b44?mp_source=share',
    avatarUrl: '/headshot.png',
    followers: '100% Job Success',
  },
];

const education = [
  {
    title: 'Engineer degree, Software Engineer',
    date: '2020-2024',
    institution: 'UNIR International University',
  },
];

const verifications = [
  {
    verificationName: 'Software Engineer Degree',
  },
];
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <div class="grid items-start gap-5 lg:grid-cols-2">
      <!-- Content -->
      <div class="hidden h-auto w-full md:block">
        <div class="h-full w-full space-y-8 rounded-2xl bg-transparent p-6 text-white">
          <Avatar avatar="/headshot.png" />
          <div class="flex justify-between border-b border-white/10 pb-6">
            {
              stats.map(({ title, value }) => (
                <div>
                  <div class="text-xl font-bold">{value}</div>
                  <div class="text-xs text-gray-400">{title}</div>
                </div>
              ))
            }
          </div>

          <div class="space-y-6">
            <h2 class="text-xl font-semibold">Meet Miguel Angel J. 👇🏻</h2>
            <div class="hover-lift group cursor-pointer rounded-xl border border-border bg-card">
              <OptimizedVideo videoId="KiLp9kVhS1k" client:only="react" />
            </div>

            <div class="space-y-2">
              <h3 class="text-lg font-medium">Hours available per week</h3>
              <p class="text-gray-300">More than 30 hrs/week</p>
              <div class="flex items-center gap-2 text-sm text-gray-400">
                <span>Open to freelance</span>
                <span class="rounded-full bg-white px-2 py-0.5 text-xs font-bold text-black">only</span>
              </div>
            </div>

            <div class="space-y-2">
              <h3 class="text-lg font-medium">Languages</h3>
              <div class="space-y-1 text-sm">
                <p><span class="font-medium text-white">English:</span> <span class="text-gray-400">Fluent</span></p>
                <p>
                  <span class="font-medium text-white">Spanish:</span>
                  <span class="text-gray-400">Native or Bilingual</span>
                </p>
              </div>
            </div>

            <div class="space-y-2">
              <h3 class="text-lg font-medium">Verifications</h3>
              <div class="space-y-1 text-sm">
                {
                  verifications.map(({ verificationName }) => (
                    <div class="flex items-center gap-2">
                      <span class="text-white">{verificationName}</span>
                      <FaCircleCheck color="#3b82f6" size={15} />
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="space-y-2">
              <h3 class="text-lg font-medium">Education</h3>
              {
                education.map(({ title, institution, date }) => (
                  <div>
                    <p class="font-medium text-white">{institution}</p>
                    <p class="text-sm text-gray-400">{title}</p>
                    <p class="text-sm text-gray-500">{date}</p>
                  </div>
                ))
              }
            </div>

            <LinkedAccounts accounts={myAccounts} />
          </div>
        </div>
      </div>

      {/* Bio Content */}
      <div class="w-full space-y-8">
        <div>
          <Badge variant="outline" className="mb-4 border-primary text-primary">
            Senior Full-Stack Engineer | AI Automation & Scalable Systems
          </Badge>

          <h2 class="mb-2 text-3xl font-bold text-foreground md:text-4xl">
            ⚡ Senior Full-Stack Engineer | AI Automation & Scalable Systems
          </h2>
        </div>

        <div class="space-y-6 text-lg leading-relaxed text-muted-foreground">
          <p>
            I don't just "integrate AI" I architect complete systems that scale. Enterprise-grade infrastructure using
            Go, Node.js, Next.js, and Custom AI agents.
          </p>

          <p class="font-semibold text-foreground">🚀 WHAT MAKES ME DIFFERENT</p>

          <p>
            Solo engineer who builds complete tech startups from scratch:<br />
             ✅ Mental health AI app → 7K+ active users<br />
             ✅ AI agent platform (Growthly AI) → 1000+ conversations/day<br />
             ✅ 15+ production AI systems → 10K+ operations/day
          </p>

          <p class="font-semibold text-foreground">🛠️ TECHNICAL CAPABILITIES</p>

          <p>
            <span class="font-medium text-foreground">AI Systems</span><br />
             Custom agents (WhatsApp, voice, support) • RAG systems • Multi-agent orchestration • LLM integration
            (OpenAI, Claude)
          </p>

          <p>
            <span class="font-medium text-foreground">Backend</span><br />
             Go microservices (10K+ req/min) • &lt;100ms latency • Scalable architecture • Advanced APIs
          </p>

          <p>
            <span class="font-medium text-foreground">Frontend</span><br />
             Next.js • Real-time dashboards • React Native • TypeScript
          </p>

          <p class="font-semibold text-foreground">💼 WHAT I BUILD</p>

          <p>
            <span class="font-medium text-foreground">Custom AI & Automation</span> (2-6 weeks)<br />
            <span class="font-medium text-foreground">High-Performance Backend</span> (1-4 weeks)<br />
            <span class="font-medium text-foreground">Marketing Tech Infrastructure</span> (2-5 weeks)<br />
            <span class="font-medium text-foreground">Tech Startup MVPs</span> (4-12 weeks)
          </p>

          <p class="font-semibold text-foreground">🔧 CORE STACK</p>

          <p>
            Backend: Go, Node.js<br />
             Frontend: Next.js 14/15, React, TypeScript, Tailwind CSS<br />
             AI: OpenAI, Claude, Custom fine-tuning<br />
             Infrastructure: AWS/GCP, Docker, Kubernetes<br />
             Databases: PostgreSQL, MongoDB, Redis
          </p>

          <p class="font-semibold text-foreground">⚡ LET'S BUILD</p>

          <p>
            📩 Get a detailed technical proposal within 48 hours.<br />
             Recent: Mental health AI (7K users) • WhatsApp AI agents • Marketing automation (+50% performance)
          </p>
        </div>

        {/* CTAs */}
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href="https://calendar.google.com/calendar/u/0/appointments/schedules/AcZssZ3T7zeEOYTFQmof-sbNifFo37K0uW123TO1tf3L6AEUr-2qhDbR8Txol7-9zoAdi6NfmfNTOtQs"
          >
            <Button variant="outline" className="group hover:bg-white hover:text-black">
              <ExternalLink className="mr-2 h-4 w-4 " />
               Book a free call
            </Button>
          </a>
          <a href="https://www.upwork.com/freelancers/~01c50c885bdb2a6b44?mp_source=share">
            <Button variant="outline" className="group hover:bg-white hover:text-black">
              <Linkedin className="mr-2 h-4 w-4 " />
               Connect on Upwork
            </Button>
          </a>
          <a href="https://www.linkedin.com/in/varmiguemunoz/">
            <Button variant="outline" className="group hover:bg-white hover:text-black">
              <Linkedin className="mr-2 h-4 w-4 " />
               Connect on LinkedIn
            </Button>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
