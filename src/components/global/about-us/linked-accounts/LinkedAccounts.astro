---
interface Account {
  platform: string;
  username: string;
  since: string;
  profileUrl: string;
  avatarUrl: string;
  followers?: string; // Opcional, ej: "7 followers" o "500+ connections"
}

interface Props {
  accounts: Account[];
}

const { accounts } = Astro.props;
---

<div class="space-y-4">
  <h3 class="text-lg font-medium text-white">Linked accounts</h3>

  <div class="space-y-3">
    {accounts.map((acc) => (
      <div class="rounded-xl bg-[#1c1c1c] p-5 transition-colors hover:bg-[#252525]">
        
        {/* Header: Platform Info & Avatar */}
        <div class="flex items-start justify-between">
          <div>
            <div class="flex items-baseline gap-2">
              <span class="text-xl font-bold text-white">{acc.platform}</span>
              <span class="text-xs text-gray-500">Since {acc.since}</span>
            </div>
            <p class="mt-1 text-sm font-medium text-gray-200">{acc.username}</p>
          </div>
          
          <img 
            src={acc.avatarUrl} 
            alt={acc.username} 
            class="h-10 w-10 rounded-full object-cover grayscale opacity-80"
          />
        </div>

        {/* Action Links */}
        <div class="mt-6 flex flex-col gap-3">
          
          {/* View Profile Link */}
          <a 
            href={acc.profileUrl} 
            target="_blank" 
            rel="noopener noreferrer"
            class="group flex items-center gap-2 text-sm font-medium text-primary hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            View profile
          </a>

          {/* Followers / Stat (Renderiza solo si existe) */}
          {acc.followers && (
            <div class="flex items-center gap-2 text-sm text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              {acc.followers}
            </div>
          )}

        </div>
      </div>
    ))}
  </div>
</div>