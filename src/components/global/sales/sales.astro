---
import Brands from '../brands/brands.astro';
import SalesForm from '../forms/sales-form.astro';
import brands from '@config/brands.json';
---

<main class="min-h-screen">
  <section class="flex flex-col gap-16 px-6 py-10 md:px-20 md:py-20 lg:px-36">
    <div class="mx-auto grid max-w-7xl items-center gap-10 md:grid-cols-2">
      <!-- Lado Izquierdo -->
      <div class="space-y-6">
        <p class="text-sm font-medium">
          📞 Talk to sales <a href="tel:+57 302-327-8057" class="text-blue-700 underline">+57 302-327-8057</a>
        </p>
        <h1 class="text-4xl font-bold leading-tight md:text-5xl">
          Save time and money <br />with <span class="text-blue-600">AI Agents</span>.
        </h1>
        <p class="text-lg">
          Discover how AI Agents solutions can help your business grow. To learn more, fill out this form.
        </p>
        <ul class="space-y-2">
          <li class="flex items-center font-medium text-blue-700">
            <span class="mr-2">✔</span> Automatize your operations
          </li>
          <li class="flex items-center font-medium text-blue-700">
            <span class="mr-2">✔</span> Save time and money
          </li>
          <li class="flex items-center font-medium text-blue-700">
            <span class="mr-2">✔</span> 24/7 service without hiring additional staff
          </li>
          <li class="flex items-center font-medium text-blue-700">
            <span class="mr-2">✔</span> Increase conversions with instant responses
          </li>
        </ul>
      </div>

      <!-- Formulario -->
      <SalesForm />
    </div>

    <Brands brands={brands} />
  </section>
</main>
