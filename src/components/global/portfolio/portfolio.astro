---
import { Badge } from '@/components/ui/badge';

const projects = [
  {
    name: 'TuVendedor24',
    description: 'AI-powered WhatsApp sales agent platform. Multi-agent architecture, lead qualification, automated scheduling.',
    url: 'https://tuvendedor24.com',
    tag: 'AI · Automation',
  },
  {
    name: 'Tao of Flow',
    description: 'AI-powered wellness iOS app. Scaled to 7,000+ daily active users under sustained load.',
    url: 'https://taoofflow.ai',
    tag: 'AI · Mobile',
  },
  {
    name: 'QliniQ',
    description: 'Case management software for PI medical clinics. Lead tracking, documentation, legal workflow integration.',
    url: null,
    tag: 'Full-Stack · SaaS',
  },
  {
    name: 'Shipday',
    description: 'AI-powered delivery management platform. Operational clarity at scale for logistics companies.',
    url: 'https://shipday.com',
    tag: 'AI · Logistics',
  },
  {
    name: 'DW Drums',
    description: 'Premium e-commerce and brand website for musical instrument manufacturer.',
    url: 'https://dwdrums.com',
    tag: 'E-commerce · Frontend',
  },
  {
    name: 'Parrolabs',
    description: 'Digital product studio positioning site.',
    url: 'https://parrolabs.com',
    tag: 'Frontend · Branding',
  },
];
---

<section class="px-6 py-24" id="work">
  <div class="mx-auto max-w-6xl">
    <div class="mb-16 text-center">
      <Badge variant="outline" className="mb-6 border-primary text-primary">Work</Badge>
      <h2 class="mb-6 text-4xl font-bold text-foreground md:text-5xl">Selected Work</h2>
      <p class="mx-auto max-w-3xl text-xl text-muted-foreground">
        Production systems. Real clients. Real load.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <div class="group flex flex-col rounded-2xl border border-border/30 bg-gradient-card p-8 transition-all duration-300 hover:border-primary/20 hover:shadow-glow">
          <div class="mb-4 flex items-start justify-between gap-4">
            <h3 class="text-xl font-bold text-foreground">{project.name}</h3>
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-xs text-primary opacity-0 transition-opacity duration-200 group-hover:opacity-100"
              >
                ↗
              </a>
            )}
          </div>

          <p class="mb-6 flex-1 leading-relaxed text-muted-foreground">
            {project.description}
          </p>

          <div class="mt-auto flex items-center justify-between">
            <span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent">
              {project.tag}
            </span>
            {project.url && (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs text-muted-foreground transition-colors duration-200 hover:text-primary"
              >
                {project.url.replace('https://', '')}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
