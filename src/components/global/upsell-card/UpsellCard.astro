---
type Props = {
  logoHtml?: string;
  title?: string;
  description?: string;
  price?: string;
  priceNote?: string;
  items?: string[];
  addHref?: string;
  cancelHref?: string;
};

const {
  logoHtml = '',
  title = '',
  description = '',
  price = '',
  priceNote = '',
  items = [],
} = Astro.props as Props;

---

<div
  class="relative mx-auto w-full max-w-2xl overflow-hidden rounded-2xl border border-border bg-gradient-card p-6 transition-all duration-300 hover:border-primary/20 hover:shadow-glow md:p-8"
>
  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"></div>
  <div
    class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-gradient-to-br from-primary/20 to-accent/20 opacity-30 blur-2xl"
  >
  </div>
  <div
    class="absolute -bottom-12 -left-12 h-56 w-56 rounded-full bg-gradient-to-br from-accent/20 to-primary/20 opacity-20 blur-3xl"
  >
  </div>

  <div class="relative flex flex-col items-center gap-4 md:flex-row">
    <div
      class="flex h-14 w-14 items-center justify-center rounded-xl border border-border bg-gradient-to-br from-primary/20 to-accent/20"
    >
      {
        logoHtml ? (
          <div class="h-7 w-7 text-primary" set:html={logoHtml} />
        ) : (
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-7 w-7 text-primary">
            <path
              fill="currentColor"
              d="M12 2l2.39 4.84 5.34.78-3.86 3.76.91 5.31L12 14.77 7.22 16.69l.91-5.31L4.27 7.62l5.34-.78L12 2z"
            />
          </svg>
        )
      }
    </div>
    <div class="w-full text-left">
      <h3
        class="bg-gradient-text w-full bg-clip-text text-[26px] font-bold leading-tight text-transparent text-white md:text-3xl"
      >
        {title}
      </h3>
      <p class="text-md mt-1 text-left text-muted-foreground md:text-base">{description}</p>
    </div>
  </div>

  <div class="relative mt-6 flex flex-col items-baseline gap-2">
    <p class="text-3xl font-extrabold leading-none text-primary md:text-4xl">{price}</p>
    {priceNote && <p class="text-[10px] text-muted-foreground/50 md:text-base lg:text-base">{priceNote}</p>}
  </div>

  <ul class="relative mt-6 space-y-3">
    {
      items.map((item) => (
        <li class="flex items-start gap-3">
          <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-gradient-to-br from-primary/30 to-accent/30">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-3.5 w-3.5 text-primary">
              <path fill="currentColor" d="M9 16.17l-3.88-3.88-1.41 1.41L9 19 20.29 7.71l-1.41-1.41z" />
            </svg>
          </span>
          <span class="text-foreground">{item}</span>
        </li>
      ))
    }
  </ul>
</div>
