---
// Tipos
interface ValueItem {
  icon: string; // SVG string
  bgColor: string; // clases bg-*
  textColor: string; // clases text-*
  title: string;
  description: string;
}

interface ValuePropositionProps {
  items?: ValueItem[];
}

// Defaults
const {
  items = [
    {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M4 6a2 2 0 0 1 2-2h5v4H6a2 2 0 0 1-2-2Zm9-2h5a2 2 0 0 1 2 2v2h-7V4Zm7 6H4v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8Z"></path></svg>`,
      bgColor: 'bg-primary/15',
      textColor: 'text-primary',
      title: 'Frictionless development',
      description: 'I integrate into your workflow without endless onboarding.',
    },
    {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M11 3a1 1 0 0 1 2 0v7h4a1 1 0 1 1 0 2h-4v7a1 1 0 1 1-2 0v-7H7a1 1 0 0 1 0-2h4V3Z"></path></svg>`,
      bgColor: 'bg-accent/15',
      textColor: 'text-accent',
      title: 'Speed and quality',
      description: 'Clean code, fast delivery, 24-hour support.',
    },
    {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5"><path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5Z"></path></svg>`,
      bgColor: 'bg-primary/15',
      textColor: 'text-primary',
      title: 'Direct relationship',
      description: 'You look good in front of the client, I make it work.',
    },
  ],
} = Astro.props as ValuePropositionProps;
---

<section id="value-proposition" class="px-4 py-5 sm:py-10">
  <div class="mx-auto w-full max-w-7xl">
    <div class="rounded-2xl border border-border bg-gradient-card p-6 sm:p-8">
      <div class="grid gap-6 sm:grid-cols-3">
        {
          items.map((item) => (
            <div class="flex items-start gap-4">
              <div
                class={`${item.bgColor} ${item.textColor} mt-1 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg`}
                set:html={item.icon}
              ></div>
              <div>
                <h3 class="mb-1 text-base font-semibold text-foreground">{item.title}</h3>
                <p class="text-sm leading-relaxed text-muted-foreground">{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
