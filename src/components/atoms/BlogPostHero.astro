---
interface Props {
  title:       string;
  description: string;
  pubDate:     Date;
  category:    string;
  readtime?:   string;
  authors?:    string[];
}

const { title, description, pubDate, category, readtime, authors } = Astro.props;

const categoryLabels: Record<string, string> = {
  'dev-tips':       'Dev Tips',
  'automation':     'Automation',
  'ai-tools':       'AI Tools',
  'agency-workflow':'Agency Workflow',
  'tech-stack':     'Tech Stack',
  'others':         'Others',
};

const label = categoryLabels[category] ?? category;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<div class="relative pt-36 pb-12 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 nebula-glow-top opacity-50"></div>

  <div class="site-container relative z-10 max-w-4xl">
    <div class="flex flex-wrap items-center gap-3 mb-6">
      <span class="font-mono text-label-sm uppercase tracking-widest text-primary px-3 py-1 rounded-full bg-primary/10 border border-primary/20">
        {label}
      </span>
      <span class="font-mono text-label-sm text-on-surface-muted">{formattedDate}</span>
      {readtime && <span class="font-mono text-label-sm text-on-surface-muted">· {readtime}</span>}
    </div>

    <h1 class="font-display text-display-lg text-white mb-6 text-balance">
      {title}
    </h1>

    <p class="text-body-lg text-on-surface-variant leading-relaxed max-w-3xl text-balance">
      {description}
    </p>

    {authors && authors.length > 0 && (
      <div class="flex items-center gap-3 mt-8 pt-8 border-t border-white/[0.06]">
        <span class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center font-mono text-xs text-primary font-bold">
          {authors[0].slice(0, 2).toUpperCase()}
        </span>
        <span class="text-body-sm text-on-surface-variant font-medium">
          {authors.join(', ')}
        </span>
      </div>
    )}
  </div>
</div>
