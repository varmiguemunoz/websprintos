---
interface Props {
  title?:     string;
  class?:     string;
  fade?:      boolean;
  noPadding?: boolean;
}

const { title = '', class: className = '', fade = false, noPadding = false } = Astro.props;
---

<div class={`terminal-window rounded-2xl overflow-hidden ${className}`}>
  <div class="h-11 bg-surface-container border-b border-white/5 flex items-center px-4 justify-between shrink-0">
    <div class="flex items-center gap-2">
      <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
      <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
      <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
    </div>
    {title && (
      <span class="font-mono text-xs text-on-surface-muted opacity-60 absolute left-1/2 -translate-x-1/2">{title}</span>
    )}
    <div class="w-16"></div>
  </div>
  <div class={`${noPadding ? '' : 'p-6'} ${fade ? 'mask-fade-bottom' : ''}`}>
    <slot />
  </div>
</div>
