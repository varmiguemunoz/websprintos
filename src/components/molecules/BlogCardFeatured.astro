---
interface Props {
  slug:        string;
  title:       string;
  description: string;
  pubDate:     Date;
  image?:      string;
  category:    string;
  readtime?:   string;
}

const { slug, title, description, pubDate, image, category, readtime } = Astro.props;

const categoryLabels: Record<string, string> = {
  'dev-tips':       'Dev Tips',
  'automation':     'Automation',
  'ai-tools':       'AI Tools',
  'agency-workflow':'Agency Workflow',
  'tech-stack':     'Tech Stack',
  'others':         'Others',
};

const label = categoryLabels[category] ?? category;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  month: 'long',
  day:   'numeric',
  year:  'numeric',
});
---

<a href={`/blog/${slug}`} class="group block">
  <article class="relative rounded-2xl bg-surface-low ghost-border overflow-hidden grid md:grid-cols-2 min-h-[340px]">
    <div class="relative overflow-hidden min-h-[240px] md:min-h-0">
      {image ? (
        <img
          src={image}
          alt={title}
          alt={`Cover image for: ${title}`}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 absolute inset-0"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-surface-container flex items-center justify-center">
          <span class="material-symbols-outlined text-6xl text-on-surface-muted opacity-20">article</span>
        </div>
      )}
      <div class="absolute inset-0 bg-gradient-to-r from-transparent to-surface-low/60 hidden md:block" />
      <div class="absolute inset-0 bg-gradient-to-t from-surface-low/80 to-transparent md:hidden" />
    </div>

    <div class="flex flex-col justify-center p-8 md:p-10 relative z-10">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 font-mono text-label-sm text-primary uppercase tracking-widest">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald animate-pulse-dot"></span>
          Latest Post
        </span>
        <span class="font-mono text-label-sm text-on-surface-muted">{label}</span>
      </div>

      <h2 class="font-display text-headline-lg text-white mb-4 leading-tight group-hover:text-primary-dim transition-colors duration-300">
        {title}
      </h2>

      <p class="text-body-md text-on-surface-variant leading-relaxed mb-6 line-clamp-3">
        {description}
      </p>

      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4 text-on-surface-muted">
          <span class="font-mono text-label-sm">{formattedDate}</span>
          {readtime && <span class="font-mono text-label-sm">· {readtime}</span>}
        </div>
        <span class="flex items-center gap-2 text-body-sm font-semibold text-primary group-hover:gap-3 transition-all duration-200">
          Read article
          <span class="material-symbols-outlined text-sm leading-none">arrow_forward</span>
        </span>
      </div>
    </div>
  </article>
</a>
