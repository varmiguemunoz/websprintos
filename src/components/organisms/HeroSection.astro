---
import { Badge }      from '@/components/atoms/Badge';
import { Button }     from '@/components/atoms/Button';
import TerminalWindow from '@/components/atoms/TerminalWindow.astro';
import type { heroContent, credibilityStats } from '@/data/hero';

interface Props {
  hero:  typeof heroContent;
  stats: typeof credibilityStats;
}

const { hero, stats } = Astro.props;
---

<section class="relative pt-40 pb-24 overflow-hidden">
  <div class="pointer-events-none absolute inset-0 nebula-glow-top"></div>

  <div class="site-container relative z-10">
    <div class="text-center max-w-5xl mx-auto">
      <div class="flex justify-center mb-8">
        <Badge client:load variant="live" dot>
          {hero.badge}
        </Badge>
      </div>

      <h1 class="font-display text-display-xl md:text-display-2xl text-white text-balance mb-6">
        {hero.title.replace(hero.titleItalic, '').trim()}{' '}
        <em class="not-italic text-primary font-light">{hero.titleItalic}</em>
      </h1>

      <p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto mb-10 text-balance">
        {hero.description}
      </p>

      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-20">
        <Button client:load href={hero.primaryCta.href} size="lg" icon="terminal">
          {hero.primaryCta.label}
        </Button>
        <Button client:load href={hero.secondaryCta.href} variant="secondary" size="lg">
          {hero.secondaryCta.label}
        </Button>
      </div>
    </div>

    <TerminalWindow
      title={hero.terminalTitle}
      class="max-w-5xl mx-auto"
      fade
      noPadding
    >
      <div class="p-6 font-mono text-mono-md leading-relaxed min-h-[300px]">
        <div class="flex gap-8 overflow-x-auto scrollbar-hide">
          {['Backlog', 'In Progress', 'In Review', 'Done'].map((col, ci) => (
            <div class="min-w-[180px]">
              <div class={`text-label-sm uppercase tracking-widest mb-4 ${ci === 1 ? 'text-primary' : 'text-on-surface-muted'}`}>
                {col} {ci === 0 ? '(8)' : ci === 1 ? '(3)' : ci === 2 ? '(2)' : '(14)'}
              </div>
              {ci === 0 && [
                '[ ] Fix memory leak',
                '[ ] Auth middleware',
                '[ ] Rate limiting',
              ].map((t,i) => (
                <div class="mb-2 text-on-surface-variant text-xs">{t}</div>
              ))}
              {ci === 1 && [
                '[→] !! Deploy v2.4',
                '[→] ↑  Write unit tests',
                '[→] Add MCP server',
              ].map((t,i) => (
                <div class={`mb-2 text-xs ${i === 0 ? 'text-primary font-semibold' : 'text-on-surface'}`}>{t}</div>
              ))}
              {ci === 2 && [
                '[⏳] PR #142 open',
                '[⏳] Code review',
              ].map((t,i) => (
                <div class="mb-2 text-on-surface-variant text-xs">{t}</div>
              ))}
              {ci === 3 && [
                '[✓] Set up CI pipeline',
                '[✓] DB migrations',
              ].map((t,i) => (
                <div class="mb-2 text-on-surface-muted text-xs line-through">{t}</div>
              ))}
            </div>
          ))}
        </div>

        <div class="mt-6 pt-4 border-t border-white/[0.04] flex items-center justify-between text-xs text-on-surface-muted">
          <span><span class="text-emerald">●</span> Timer: 01:23:45 — Deploy v2.4</span>
          <span>? help  q quit  n new  T timer</span>
        </div>
      </div>
    </TerminalWindow>
  </div>
</section>

<section class="border-y border-white/[0.03] bg-surface/60 py-14">
  <div class="site-container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {stats.map(stat => (
        <div class="flex flex-col items-center text-center">
          <span class="font-display text-headline-md text-white mb-1">{stat.label}</span>
          <span class={`font-mono text-label-sm uppercase tracking-widest ${stat.accent === 'secondary' ? 'text-secondary' : 'text-primary'}`}>
            {stat.sub}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
