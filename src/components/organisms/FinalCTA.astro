---
import { Button } from '@/components/atoms/Button';

interface Props {
  title:       string;
  description: string;
  primaryCta:  { label: string; href: string };
  secondaryCta:{ label: string; href: string };
}

const { title, description, primaryCta, secondaryCta } = Astro.props;
---

<section class="py-24 bg-surface">
  <div class="site-container">
    <div class="relative rounded-3xl p-16 md:p-24 text-center overflow-hidden bg-surface-container ghost-border">
      <div class="pointer-events-none absolute inset-0 nebula-glow-top opacity-80"></div>

      <div class="relative z-10 max-w-2xl mx-auto">
        <p class="font-mono text-label-sm uppercase tracking-widest text-primary mb-6">Get Started Today</p>
        <h2 class="font-display text-display-xl text-white mb-6 text-balance">
          {title}
        </h2>
        <p class="text-body-lg text-on-surface-variant mb-10 text-balance">
          {description}
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <Button client:load href={primaryCta.href} size="lg" icon="terminal">
            {primaryCta.label}
          </Button>
          <Button client:load href={secondaryCta.href} variant="secondary" size="lg" icon="code">
            {secondaryCta.label}
          </Button>
        </div>

        <p class="text-body-sm text-on-surface-muted mt-8">
          Free forever · MIT licensed · No credit card required
        </p>
      </div>
    </div>
  </div>
</section>
